{
  "name": "widget",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev --port 3001",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "build:embed": "vite build --config vite.embed.config.ts",
    "dev:embed": "vite build --config vite.embed.config.ts --watch",
    "predev": "node scripts/ensure-embed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-router/node": "^7.9.2",
    "@react-router/serve": "^7.9.2",
    "@t3-oss/env-core": "^0.13.8",
    "isbot": "^5.1.31",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@react-router/dev": "^7.9.2",
    "@repo/eslint-config": "*",
    "@repo/types": "*",
    "@repo/typescript-config": "*",
    "@repo/ui": "*",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}