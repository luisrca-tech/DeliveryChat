---
import { getLogoPublicSrc } from "../../lib/logoPublicSrc";

const logoSrc = getLogoPublicSrc();
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="flex items-center gap-3 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      >
        <img
          src={logoSrc}
          alt=""
          width="600"
          height="328"
          class="block h-[60px] w-auto max-w-[min(18rem,calc(100vw-12rem))] object-contain object-left shrink-0"
        />
        <span
          class="text-xl font-bold bg-linear-to-r from-primary to-primary-glow bg-clip-text text-transparent"
        >
          Delivery Chat
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-8">
        <a
          href="#features"
          class="text-sm font-medium text-foreground/80 hover:text-primary transition-colors"
        >
          Features
        </a>
        <a
          href="#how-it-works"
          class="text-sm font-medium text-foreground/80 hover:text-primary transition-colors"
        >
          How It Works
        </a>
        <a
          href="#pricing"
          class="text-sm font-medium text-foreground/80 hover:text-primary transition-colors"
        >
          Pricing
        </a>
        <a
          href="#testimonials"
          class="text-sm font-medium text-foreground/80 hover:text-primary transition-colors"
        >
          Testimonials
        </a>
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="/register"
          class="inline-flex items-center justify-center h-8 rounded-md px-3 text-sm font-medium bg-gradient-hero hover:shadow-glow transition-all duration-300 text-primary-foreground"
        >
          Get Started
        </a>
      </div>
    </div>
  </div>
</header>
