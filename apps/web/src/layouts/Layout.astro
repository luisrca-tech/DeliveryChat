---
import "@repo/ui/styles.css";
import { Toaster } from "@repo/ui/components/ui/sonner";
import { getFaviconPublicSrc } from "../lib/faviconPublicSrc";
import { getApiUrl } from "../lib/urls";

const widgetApiBaseUrl = getApiUrl();
const faviconSrc = getFaviconPublicSrc();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href={faviconSrc} sizes="any" />
    <link rel="apple-touch-icon" href={faviconSrc} sizes="180x180" />
    <meta name="generator" content={Astro.generator} />
    <title>Delivery Chat - Multi-tenant Chat Platform</title>
  </head>
  <body>
    <slot />
    <Toaster client:load richColors />

    <script is:inline src={`${widgetApiBaseUrl}/widget.js`}></script>
    <script is:inline define:vars={{ widgetApiBaseUrl }}>
      DeliveryChat.init({
        appId: "e8c1d61e-6abf-4a93-bfb3-62a12b2129b3",
        apiBaseUrl: widgetApiBaseUrl,
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    width: 100%;
    height: 100%;
  }
</style>
