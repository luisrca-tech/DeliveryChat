---
import "@repo/ui/styles.css";
import { Toaster } from "@repo/ui/components/ui/sonner";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Delivery Chat - Multi-tenant Chat Platform</title>
  </head>
  <body>
    <slot />
    <Toaster client:load richColors />

    <script is:inline src="https://api.deliverychat.online/widget.js"></script>
    <script is:inline>
      DeliveryChat.init({
        appId: "e8c1d61e-6abf-4a93-bfb3-62a12b2129b3",
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    width: 100%;
    height: 100%;
  }
</style>
