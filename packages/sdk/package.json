{
  "name": "@deliverychat/sdk",
  "version": "0.1.0",
  "description": "DeliveryChat JavaScript SDK — embeddable chat widget with headless mode, typed events, and visitor identity",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "check-bundle-size": "node scripts/CheckBundleSize.js",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
